# Supabase (dynamic checklist state)
# Copy this file to .env.local and fill in real values for local dev.
# Missing values => checklist toggles work in-session but don't persist.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Owner editing API (server-only in Vercel / vercel dev)
ADMIN_PIN=
TRIP_EDITOR_PIN=
SUPABASE_SERVICE_ROLE_KEY=

# Optional smart trip generation AI composer (server-only).
# If OPENAI_API_KEY is missing or the model response fails validation,
# /trips/new still succeeds with the deterministic smart draft fallback.
OPENAI_API_KEY=
TRIP_GENERATION_MODEL=gpt-5.5
