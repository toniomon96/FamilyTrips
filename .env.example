# Supabase (dynamic checklist state)
# Copy this file to .env.local and fill in real values for local dev.
# Missing values => checklist toggles work in-session but don't persist.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Owner editing API (server-only in Vercel / vercel dev)
ADMIN_PIN=
TRIP_EDITOR_PIN=
SUPABASE_SERVICE_ROLE_KEY=

# Optional smart trip generation AI research/composer (server-only).
# Live research uses OpenAI web search when configured. The experimental AI
# composer is off by default because the deterministic planner is more reliable.
OPENAI_API_KEY=
TRIP_RESEARCH_MODEL=gpt-5-mini
TRIP_RESEARCH_ENABLED=1
TRIP_RESEARCH_MAX_QUERIES=4
TRIP_RESEARCH_TIMEOUT_MS=60000
TRIP_AI_PLANNER_ENABLED=0
TRIP_GENERATION_MODEL=gpt-5-mini
TRIP_PLANNER_TIMEOUT_MS=60000

# Optional API guardrails for trusted PIN planning endpoints.
# Defaults are intentionally conservative for casual family/friends use.
TRIP_API_RATE_LIMIT=60
TRIP_API_RATE_WINDOW_MS=60000
TRIP_API_MAX_BODY_BYTES=262144

# Optional UAT runner controls. The runner creates a one-time PIN for
# temporary deployments and never needs the permanent TRIP_EDITOR_PIN.
UAT_TARGET=preview
UAT_PRODUCTION_URL=https://thegroupchat.voyage
UAT_KEEP_DEPLOYMENT=
UAT_KEEP_DATA=
UAT_SCENARIOS=
