{
  "name": "triphub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "validate:data": "node scripts/validate-data.mjs",
    "uat": "powershell -ExecutionPolicy Bypass -File scripts/uat-smart-trip-smoke.ps1",
    "uat:quick": "powershell -ExecutionPolicy Bypass -File scripts/uat-smart-trip-smoke.ps1 -Scenarios smart-trip,production-smoke",
    "uat:smart-trip": "powershell -ExecutionPolicy Bypass -File scripts/uat-smart-trip-smoke.ps1 -Scenarios smart-trip,production-smoke",
    "uat:browser": "powershell -ExecutionPolicy Bypass -File scripts/uat-smart-trip-smoke.ps1 -Scenarios browser",
    "uat:production": "powershell -ExecutionPolicy Bypass -File scripts/uat-smart-trip-smoke.ps1 -Scenarios production-smoke",
    "ready:production": "node scripts/production-readiness.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.5"
  }
}
